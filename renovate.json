{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboardApproval": false,
  "prHourlyLimit": 10,
  "enabledManagers": ["nix", "custom.regex"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["on saturday"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.nix$/"],
      "matchStrings": [
        "image = \"(?<depName>[^:\"]+):(?<currentValue>[^@:\"]+)(?:@(?<currentDigest>[^\"]+))?\""
      ],
      "autoReplaceStringTemplate": "image = \"{{{depName}}}:{{{currentValue}}}@{{{newDigest}}}\"",
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Automerge nix flake input updates after CI passes",
      "matchManagers": ["nix"],
      "schedule": ["on saturday"],
      "automerge": true
    },
    {
      "description": "Open PRs for container image updates as soon as new digests are available",
      "matchManagers": ["custom.regex"],
      "pinDigests": true,
      "dependencyDashboardApproval": false
    }
  ]
}
