{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboardApproval": false,
  "prHourlyLimit": 10,
  "enabledManagers": ["nix", "custom.regex"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["on saturday"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.nix$"],
      "matchStrings": [
        "image = \"(?<depName>[^:\"]+):(?<currentValue>[^@:\"]+)(?:@(?<currentDigest>[^\"]+))?\""
      ],
      "autoReplaceStringTemplate": "image = \"{{{depName}}}:{{{newValue}}}@{{{newDigest}}}\"",
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Open PRs for nix flake input updates on Saturdays — no automerge, review manually to catch Caddy plugin hash changes",
      "matchManagers": ["nix"],
      "schedule": ["on saturday"]
    },
    {
      "description": "Automerge container image digest updates after CI passes",
      "matchManagers": ["custom.regex"],
      "pinDigests": true,
      "dependencyDashboardApproval": false,
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Ignore postgres major version bumps — requires manual data migration",
      "matchDepNames": ["docker.io/postgres"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
