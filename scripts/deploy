#!/usr/bin/env bash
# scripts/deploy — homelab deploy helper
#
# Usage:
#   deploy                    Deploy all hosts: mirkwood first (cache primer),
#                             then rivendell + pirateship in parallel
#   deploy mirkwood           Deploy a single host
#   deploy rivendell
#   deploy pirateship
#
# NOTE: For DNS changes (modules/dns.nix), always deploy rivendell before
# mirkwood manually — this script does not enforce that ordering.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLAKE="${SCRIPT_DIR}/.."

run_deploy() {
  nix run --option accept-flake-config true github:serokell/deploy-rs -- "$FLAKE#$1"
}

case "${1:-all}" in
  mirkwood|rivendell|pirateship)
    run_deploy "$1"
    ;;
  all)
    # Mirkwood goes first: it builds its own closure, which includes the shared
    # kernel (linux_rpi-bcm2712). The post-build hook pushes everything to attic.
    # Rivendell and pirateship then get cache hits on all shared derivations.
    run_deploy mirkwood

    run_deploy rivendell &
    pid_r=$!
    run_deploy pirateship &
    pid_p=$!

    status=0
    wait "$pid_r" || status=$?
    wait "$pid_p" || { [[ $status -eq 0 ]] && status=$?; }
    exit $status
    ;;
  *)
    echo "Usage: deploy [mirkwood|rivendell|pirateship]" >&2
    exit 1
    ;;
esac
