#!/usr/bin/env bash
# scripts/deploy — homelab deploy helper
#
# Usage:
#   deploy                    Deploy all hosts in weekly-safe order:
#                               1. orthanc  (remote builder — warms attic cache)
#                               2. mirkwood (primary DNS + cache primer for Pis)
#                               3. rivendell + pirateship in parallel
#                             mirkwood completes before rivendell starts so DNS
#                             redundancy is maintained throughout.
#   deploy mirkwood           Deploy a single host
#   deploy rivendell
#   deploy pirateship
#   deploy orthanc
#
# NOTE: For DNS changes (modules/dns.nix), always deploy rivendell before
# mirkwood manually — this script does not enforce that ordering.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLAKE="${SCRIPT_DIR}/.."

run_deploy() {
  local host="$1"
  local log
  log=$(mktemp)
  # deploy-rs exits 0 even on activation failure; detect via output
  nix run --option accept-flake-config true github:serokell/deploy-rs -- "$FLAKE#$host" 2>&1 | tee "$log"
  if grep -q '\[ERROR\]' "$log"; then
    rm -f "$log"
    echo "deploy: $host activation failed (deploy-rs reported ERROR)" >&2
    return 1
  fi
  rm -f "$log"
}

case "${1:-all}" in
  mirkwood|rivendell|pirateship|orthanc)
    run_deploy "$1"
    ;;
  all)
    # Orthanc first: x86_64 remote builder for all Pis. Deploying it first
    # ensures it's available and warm for the Pi builds that follow.
    run_deploy orthanc

    # Mirkwood second: builds its closure (including the shared linux_rpi-bcm2712
    # kernel) and pushes to attic. Rivendell and pirateship get cache hits.
    # Must complete before rivendell starts to maintain DNS redundancy.
    run_deploy mirkwood

    run_deploy rivendell &
    pid_r=$!
    run_deploy pirateship &
    pid_p=$!

    status=0
    wait "$pid_r" || status=$?
    wait "$pid_p" || { [[ $status -eq 0 ]] && status=$?; }
    exit $status
    ;;
  *)
    echo "Usage: deploy [mirkwood|rivendell|pirateship|orthanc]" >&2
    exit 1
    ;;
esac
