#!/usr/bin/env bash
# scripts/merge-renovate — safe workflow for Renovate lockfile maintenance PRs
#
# Full workflow:
#   1.  Find the open renovate/lock-file-maintenance PR on GitHub
#   2.  Fetch the branch and copy its flake.lock into the working tree
#       (stays on main — avoids losing scripts when checking out renovate's branch)
#   3.  nix flake check --no-build with the new lock
#   4.  Deploy to all homelab hosts (mirkwood first, then rivendell + pirateship)
#   5.  Wait for services to settle
#   6.  Run scripts/validate to confirm all key services are healthy
#   7a. On success: merge the PR via gh, pull main
#   7b. On failure: restore flake.lock, print actionable guidance, exit 1
#
# Flags:
#   --skip-deploy     Skip deploy step (use if already deployed from this lock)
#   --skip-validate   Skip validation step (use with caution)
#   --no-push         Dry-run mode: do everything except the final merge/push
#   --pr <number>     Target a specific PR by number (branch resolved automatically)
#   --branch <name>   Target a specific branch (finds its open PR on GitHub)
#                     Default: renovate/lock-file-maintenance
#
# Common failure modes and remediation:
#   • nix flake check fails with a hash mismatch
#       — Caddy version bumped in nixpkgs. The error output contains the correct
#         hash ("got: sha256-..."). Update it in modules/caddy.nix, commit the
#         fix, push it to the PR branch, then re-run this script:
#             git push origin HEAD:renovate/lock-file-maintenance
#   • Deploy fails (deploy-rs exits non-zero with magic rollback)
#       — Hosts have rolled back automatically. Check the deploy output above.
#         Fix the issue, commit, push to the PR branch (see above), re-run.
#   • Validation fails
#       — Services deployed but something is wrong. Check the failed checks.
#         SSH into the affected host: ssh brian@<host> journalctl -u <service> -e
#         Fix, commit, push to the PR branch, re-run with --skip-deploy.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLAKE_DIR="${SCRIPT_DIR}/.."
REPO="bcrescimanno/homelab-nix"
DEFAULT_BRANCH="renovate/lock-file-maintenance"
SETTLE_SECONDS=45

SKIP_DEPLOY=false
SKIP_VALIDATE=false
NO_PUSH=false
LOCK_SWAPPED=false
EPP_BOOSTED=false
ORTHANC_HOST="orthanc.home.theshire.io"
EPP_NORMAL="balance_power"
EPP_BUILD="performance"
PR_NUMBER=""
BRANCH=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --skip-deploy)   SKIP_DEPLOY=true; shift ;;
    --skip-validate) SKIP_VALIDATE=true; shift ;;
    --no-push)       NO_PUSH=true; shift ;;
    --pr)            PR_NUMBER="${2:?--pr requires a PR number}"; shift 2 ;;
    --branch)        BRANCH="${2:?--branch requires a branch name}"; shift 2 ;;
    -h|--help)
      sed -n '2,50p' "$0" | grep '^#' | sed 's/^# \?//'
      exit 0
      ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

# Default branch when neither --pr nor --branch was given
[[ -z "$PR_NUMBER" && -z "$BRANCH" ]] && BRANCH="$DEFAULT_BRANCH"

# ─── Color helpers ────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

step()    { echo -e "\n${BOLD}${CYAN}▶ $1${NC}"; }
ok()      { echo -e "  ${GREEN}✓${NC} $1"; }
warn()    { echo -e "  ${YELLOW}⚠${NC} $1"; }
die()     { echo -e "\n${RED}${BOLD}✗ $1${NC}\n" >&2; exit 1; }
hint()    { echo -e "  ${YELLOW}↳ Hint:${NC} $1"; }

# Cleanup handler: restore flake.lock and orthanc EPP on any exit.
cleanup() {
  if $LOCK_SWAPPED; then
    echo -e "\n  ${YELLOW}↳${NC} Restoring original flake.lock (branch stays on main)"
    git restore -- flake.lock 2>/dev/null || true
  fi
  if $EPP_BOOSTED; then
    echo -e "  ${YELLOW}↳${NC} Restoring orthanc EPP to ${EPP_NORMAL}"
    ssh -o ConnectTimeout=5 -o BatchMode=yes "brian@${ORTHANC_HOST}" \
      "for f in /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference; do echo ${EPP_NORMAL} | sudo tee \$f > /dev/null; done" \
      2>/dev/null || echo "    (could not reach orthanc to restore EPP — restore manually)"
    EPP_BOOSTED=false
  fi
}
trap cleanup EXIT

# set_orthanc_epp LEVEL
#   Switches orthanc's CPU EPP to the given level (e.g. "performance", "balance_power").
#   Silently skips if orthanc is unreachable.
set_orthanc_epp() {
  local level="$1"
  ssh -o ConnectTimeout=5 -o BatchMode=yes "brian@${ORTHANC_HOST}" \
    "for f in /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference; do echo ${level} | sudo tee \$f > /dev/null; done" \
    2>/dev/null
}

# ─── Preflight checks ─────────────────────────────────────────────────────────

step "Preflight"

cd "$FLAKE_DIR"

if ! command -v gh &>/dev/null; then
  die "gh (GitHub CLI) is not installed. Install it and run: gh auth login"
fi
if ! gh auth status &>/dev/null; then
  die "gh is not authenticated. Run: gh auth login"
fi

# Must be on main
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if [[ "$CURRENT_BRANCH" != "main" ]]; then
  die "Expected to be on 'main', but on '$CURRENT_BRANCH'. Run: git checkout main"
fi

# Working tree must be clean (flake.lock aside — we manage that ourselves)
DIRTY=$(git status --porcelain | grep -v '^.. flake.lock' || true)
if [[ -n "$DIRTY" ]]; then
  die "Working tree is dirty (non-flake.lock changes). Stash or commit them first."
fi

ok "On main, working tree is clean"

# ─── Step 1: Find the PR ──────────────────────────────────────────────────────

step "Finding open PR"

if [[ -n "$PR_NUMBER" ]]; then
  # --pr mode: resolve branch and metadata from the PR number
  PR_JSON=$(gh pr view "$PR_NUMBER" --repo "$REPO" --json number,title,url,headRefName 2>/dev/null) \
    || die "Could not look up PR #${PR_NUMBER} — is gh authenticated?"
  BRANCH=$(echo  "$PR_JSON" | jq -r '.headRefName')
  PR_TITLE=$(echo "$PR_JSON" | jq -r '.title')
  PR_URL=$(echo   "$PR_JSON" | jq -r '.url')
else
  # branch mode (default or --branch): find the open PR by branch name
  PR_JSON=$(gh pr list \
    --repo "$REPO" \
    --head "$BRANCH" \
    --state open \
    --json number,title,url \
    2>/dev/null)
  PR_NUMBER=$(echo "$PR_JSON" | jq -r '.[0].number // empty')
  PR_TITLE=$(echo  "$PR_JSON" | jq -r '.[0].title  // empty')
  PR_URL=$(echo    "$PR_JSON" | jq -r '.[0].url    // empty')

  if [[ -z "$PR_NUMBER" ]]; then
    warn "No open PR found for branch '$BRANCH'."
    hint "Check: gh pr list --repo $REPO"
    die "No PR to merge."
  fi
fi

ok "Found PR #${PR_NUMBER}: ${PR_TITLE}"
echo "    ${PR_URL}"

# ─── Step 2: Swap in the renovate flake.lock ─────────────────────────────────

step "Fetching renovate flake.lock (staying on main)"

git fetch origin "${BRANCH}"

# Show what changed in the lock file
LOCK_DIFF=$(git diff "origin/${BRANCH}" -- flake.lock 2>/dev/null | grep '^[-+].*"rev"' | wc -l | tr -d ' ')
ok "Fetched origin/${BRANCH} (${LOCK_DIFF} rev changes in flake.lock)"

# Copy only flake.lock from the renovate branch into the working tree.
# We stay on main — all scripts, modules, and configs remain intact.
git checkout "origin/${BRANCH}" -- flake.lock
LOCK_SWAPPED=true

ok "flake.lock updated from renovate branch (main branch preserved)"
hint "On failure, the trap handler restores the original flake.lock automatically."

# ─── Step 3: Flake check ──────────────────────────────────────────────────────

step "Running nix flake check --no-build"
hint "If this fails with a hash mismatch, look for 'got: sha256-...' in the error."
hint "That's the new Caddy plugin hash — update modules/caddy.nix, commit it, then:"
hint "  git push origin HEAD:${BRANCH}"
hint "  (re-run this script after pushing the fix)"

if ! nix flake check --no-build; then
  die "Flake check failed — see output above."
fi

ok "Flake check passed"

# ─── Step 4: Deploy ───────────────────────────────────────────────────────────

if $SKIP_DEPLOY; then
  warn "Skipping deploy (--skip-deploy)"
else
  step "Deploying to homelab (mirkwood → rivendell + pirateship)"
  hint "This builds on each Pi remotely (remoteBuild=true). May take several minutes."
  hint "If deploy fails, hosts automatically roll back (magic rollback is enabled)."

  # Boost orthanc's CPU EPP for the build. Kernel updates require compiling via
  # QEMU (aarch64 cross-compile) which is CPU-intensive. EPP balance_power caps
  # all-core boost; performance lets the firmware run at full sustained frequency.
  # The cleanup trap restores balance_power when we're done regardless of outcome.
  if set_orthanc_epp "$EPP_BUILD"; then
    EPP_BOOSTED=true
    ok "orthanc EPP → ${EPP_BUILD} (will restore ${EPP_NORMAL} after deploy)"
  else
    warn "Could not reach orthanc to set EPP (skipping — build will proceed at normal EPP)"
  fi

  if ! "${SCRIPT_DIR}/deploy"; then
    echo -e "\n${RED}${BOLD}Deploy failed.${NC}"
    hint "Hosts have automatically rolled back to their previous configuration."
    hint "Check the deploy output above for the root cause."
    hint "Fix the issue, commit it, push to the PR branch:"
    hint "  git push origin HEAD:${BRANCH}"
    hint "Then re-run this script."
    die "Deploy failed."
  fi

  ok "Deploy succeeded"
fi

# ─── Step 5: Wait for services to settle ─────────────────────────────────────

if ! $SKIP_DEPLOY && ! $SKIP_VALIDATE; then
  step "Waiting ${SETTLE_SECONDS}s for services to settle after deployment"
  for ((i=SETTLE_SECONDS; i>0; i--)); do
    printf "\r  Waiting %2ds…" "$i"
    sleep 1
  done
  printf "\r  %-30s\n" "Done waiting."
fi

# ─── Step 6: Validate ─────────────────────────────────────────────────────────

if $SKIP_VALIDATE; then
  warn "Skipping validation (--skip-validate)"
else
  step "Running service health checks"

  if ! "${SCRIPT_DIR}/validate"; then
    echo -e "\n${RED}${BOLD}Validation failed.${NC}"
    hint "Services deployed but not all healthy. Check the failed checks above."
    hint "SSH into the affected host:"
    hint "  ssh brian@<host> journalctl -u <service> -e"
    hint "Fix, commit, push to the PR branch, then re-run with --skip-deploy."
    die "Validation failed — not merging."
  fi

  ok "All validation checks passed"
fi

# ─── Step 7: Merge ────────────────────────────────────────────────────────────

if $NO_PUSH; then
  warn "--no-push: skipping merge (dry run complete)"
  echo -e "\n${GREEN}${BOLD}Dry run complete.${NC} Deploy and validation succeeded."
  echo "  Re-run without --no-push to complete the merge."
  # Leave flake.lock swapped in — no restore on this path
  LOCK_SWAPPED=false
  exit 0
fi

step "Merging PR #${PR_NUMBER} to main"

# If we committed any fixes on main that need to go into the PR, push them first.
FIXES_AHEAD=$(git rev-list "origin/main..HEAD" --count 2>/dev/null || echo 0)
if [[ "$FIXES_AHEAD" -gt 0 ]]; then
  ok "Pushing ${FIXES_AHEAD} fix commit(s) from main to origin/${BRANCH}"
  git push origin "HEAD:${BRANCH}"
fi

# Merge via GitHub — creates a merge commit, closes PR, preserves PR # in history.
gh pr merge "$PR_NUMBER" \
  --repo "$REPO" \
  --merge \
  --subject "$PR_TITLE" \
  --delete-branch

ok "PR #${PR_NUMBER} merged on GitHub"

# Pull main to get the merge commit (which includes the updated flake.lock).
# The trap handler would restore flake.lock on exit, but since the merge commit
# already has the renovate flake.lock, after pulling we'll be up to date.
LOCK_SWAPPED=false   # don't restore — the merge commit has the correct lock
git pull origin main

ok "main is up to date with the merged flake.lock"

# ─── Done ─────────────────────────────────────────────────────────────────────

echo
echo -e "${GREEN}${BOLD}✓ PR #${PR_NUMBER} merged successfully.${NC}"
echo "  Local main reflects the merged flake.lock."
echo
